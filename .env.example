# Copy this file to .env and fill in your API keys

# Groq API Key (currently active) — get free key at https://console.groq.com
VITE_GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key (backup service, not active) — get free key at https://aistudio.google.com
VITE_GEMINI_API_KEY=your_gemini_api_key_here
